rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper: check that a numeric field changed by exactly +1 or -1
    function changedByOne(field) {
      let current = resource.data.get(field, 0);
      return request.resource.data[field] == current + 1
          || request.resource.data[field] == current - 1;
    }

    function isAdmin() {
      return isAuth()
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    // Posts
    match /posts/{postId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 5000;
      // Owner can edit their own post; others can only bump counters by ±1
      allow update: if isAuth() && (
        isOwner(resource.data.authorId) ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'commentCount'])
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['likeCount'])    || changedByOne('likeCount')
          )
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['commentCount']) || changedByOne('commentCount')
          )
        )
      );
      allow delete: if isAuth() && (isOwner(resource.data.authorId) || isAdmin());

      match /likes/{likeId} {
        allow read: if isAuth();
        allow write: if isAuth() && likeId == request.auth.uid;
      }

      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
        allow delete: if isAuth() && isOwner(resource.data.authorId);
        allow update: if false;
      }
    }

    // Conversations (direct messages)
    match /conversations/{conversationId} {
      allow read: if isAuth() && (resource == null || request.auth.uid in resource.data.participantIds);
      // Participants may only touch the fields the app actually updates.
      allow update: if isAuth()
        && request.auth.uid in resource.data.participantIds
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastMessage', 'lastMessageAt', 'lastMessageSenderId', 'unreadBy',
                      'participantNames', 'participantColors']);
      // Enforce exactly two participants; caller must be one of them.
      allow create: if isAuth()
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds.size() == 2;

      match /messages/{messageId} {
        allow read: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 2000;
        allow update, delete: if false;
      }
    }

    // Users
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && isOwner(userId);
      // Only the owner may update their own profile.
      // followerCount / followingCount are maintained by Cloud Functions (Admin SDK),
      // so no client-side permission is needed for those fields.
      allow update: if isAuth()
        && isOwner(userId)
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin'])
          || isAdmin()
        );
      allow delete: if isOwner(userId);

      // Notifications: owner has full access; any authed user can create (with required fields)
      match /notifications/{notifId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isAuth()
          && request.resource.data.keys().hasAll(['type', 'actorId', 'createdAt'])
          && request.resource.data.actorId == request.auth.uid
          && request.resource.data.type in ['like', 'comment', 'follow', 'mention',
                                             'circle_invite', 'circle_join_request', 'circle_session'];
      }

      // Interview prep progress: only the owner manages their progress
      match /interviewProgress/{questionId} {
        allow read, write: if isAuth() && isOwner(userId);
      }

      // Following: only the owner manages who they follow
      match /following/{targetId} {
        allow read, write: if isOwner(userId);
      }

      // Followers: owner and the follower themselves can write (followerId == auth.uid)
      match /followers/{followerId} {
        allow read: if isAuth();
        allow write: if isAuth() && isOwner(followerId);
      }
    }

    // Video calls — readable/writable only by the two participants
    match /calls/{callId} {
      function isParticipant() {
        return request.auth.uid == resource.data.callerId
            || request.auth.uid == resource.data.calleeId;
      }
      function isCallParticipant() {
        let call = get(/databases/$(database)/documents/calls/$(callId)).data;
        return request.auth.uid == call.callerId
            || request.auth.uid == call.calleeId;
      }
      allow read: if isAuth() && isParticipant();
      allow create: if isAuth()
        && request.resource.data.callerId == request.auth.uid
        && request.resource.data.status == 'ringing';
      // Participants may only transition the call status — room name is immutable.
      allow update: if isAuth() && isParticipant()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if isAuth() && isParticipant();

      // Shared code editor state — both call participants can read/write
      match /sharedEditor/{docId} {
        allow read, write: if isAuth() && isCallParticipant();
      }
    }

    // Circles
    match /circles/{circleId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuth()
        && get(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid)).data.role == 'admin';
      allow delete: if isAuth()
        && resource.data.creatorId == request.auth.uid;

      match /members/{uid} {
        allow read: if isAuth();
        // Self-join or admin-invite
        allow create: if isAuth()
          && (uid == request.auth.uid
              || get(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid)).data.role == 'admin');
        // Admin or self can update/delete
        allow update, delete: if isAuth()
          && (uid == request.auth.uid
              || get(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid)).data.role == 'admin');
      }

      match /posts/{postId} {
        allow read: if isAuth();
        allow create: if isAuth()
          && request.resource.data.authorId == request.auth.uid;
        allow update: if isAuth() && (
          isOwner(resource.data.authorId) ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'commentCount'])
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['likeCount'])    || changedByOne('likeCount')
            )
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['commentCount']) || changedByOne('commentCount')
            )
          )
        );
        allow delete: if isAuth() && isOwner(resource.data.authorId);

        match /likes/{likeId} {
          allow read: if isAuth();
          allow write: if isAuth() && likeId == request.auth.uid;
        }

        match /comments/{commentId} {
          allow read: if isAuth();
          allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
          allow delete: if isAuth() && isOwner(resource.data.authorId);
          allow update: if false;
        }
      }
    }

    // Collection group query on circle members (used by getMyCircles$)
    match /{path=**}/members/{uid} {
      allow read: if isAuth();
    }

    // Circle live sessions
    match /circleSessions/{sessionId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // Practice sessions — private per user, immutable after creation
    match /practiceSessions/{sessionId} {
      allow read: if isAuth() && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isAuth()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100
        && (!request.resource.data.keys().hasAny(['level']) || request.resource.data.level in ['Easy', 'Medium', 'Hard']);
      allow update, delete: if false;
    }
  }
}
